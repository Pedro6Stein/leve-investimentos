{
  "compilerOptions": {
    "target": "ES6",
    "module": "ES6",
    "rootDir": "./",
    "outDir": "./dist",
    "removeComments": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "shared/**/*",
    "systems/**/*"
  ]
}